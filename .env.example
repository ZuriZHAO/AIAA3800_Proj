# EmotiCompanion 环境变量模板
# 用法：复制本文件为 .env（同目录），把下面的 key 换成真实值。
#   cp .env.example .env      # 然后编辑 .env 填入 key
# .env 已被 .gitignore 忽略，密钥不会进 git。speech_emotion.py 与 llm_reason.py
# 启动时都会 load_dotenv() 读取本文件。

# ===== 语音情绪 ③ (M2) · Qwen-Omni（经 Zhizengzeng 网关）=====
ZHIZENGZENG_API_KEY=your_qwen_api_key_here
ZHIZENGZENG_BASE_URL=https://api.zhizengzeng.com/v1
AUDIO_MODEL=qwen3-omni-flash
SPEECH_MAX_AUDIO_BYTES=8388608
# 若你的 qwen key 是阿里云 DashScope 原生 key（而非 Zhizengzeng 网关），改成：
#   ZHIZENGZENG_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   AUDIO_MODEL=qwen-omni-turbo   （按你实际可用的 omni 模型名调整）

# ===== LLM 需求推理 ⑤ (M3) · DeepSeek（OpenAI 兼容 API）=====
EMOTI_LLM_BACKEND=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 可选覆盖（一般不用改，llm_reason.py 已内置 deepseek 默认值）：
#   EMOTI_LLM_BASE_URL=https://api.deepseek.com
#   EMOTI_LLM_MODEL=deepseek-chat
# 想暂时不用真实 LLM、只跑本地规则版推理：把 EMOTI_LLM_BACKEND 改成 rule
